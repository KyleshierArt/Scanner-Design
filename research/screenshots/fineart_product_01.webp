00 aspect-3/4" data-v-c2ab6542><div class="el-image w-full h-full img-hover" data-v-c2ab6542><!--[--><!--v-if--><div class="el-image__wrapper"><!--[--><div class="el-image__placeholder"></div><!--]--></div><!--]--><!--v-if--></div></div><p class="text-center text-30 font-500 mt-20" data-v-c2ab6542>Modern Farmhouse</p></a></div><div class="col-sm-4 col-12" data-v-c2ab6542><a href="/zone-detail/9/creamy-modern-art" class="block" data-v-c2ab6542><div class="overflow-hidden bg-gray-100 aspect-3/4" data-v-c2ab6542><div class="el-image w-full h-full img-hover" data-v-c2ab6542><!--[--><!--v-if--><div class="el-image__wrapper"><!--[--><div class="el-image__placeholder"></div><!--]--></div><!--]--><!--v-if--></div></div><p class="text-center text-30 font-500 mt-20" data-v-c2ab6542>Soft Minimalism</p></a></div><div class="col-sm-4 col-12" data-v-c2ab6542><a href="/zone-detail/1/modern-minimalist-abstract-art" class="block" data-v-c2ab6542><div class="overflow-hidden bg-gray-100 aspect-3/4" data-v-c2ab6542><div class="el-image w-full h-full img-hover" data-v-c2ab6542><!--[--><!--v-if--><div class="el-image__wrapper"><!--[--><div class="el-image__placeholder"></div><!--]--></div><!--]--><!--v-if--></div></div><p class="text-center text-30 font-500 mt-20" data-v-c2ab6542>Modern Minimalism</p></a></div><!--]--></div><!--]--></div></section><section class="sec-art" data-v-c2ab6542><div class="container" data-v-c2ab6542><a href="/custom-paint/HPOP" class="make-wrapper" data-v-c2ab6542><div class="make-box flex-1 bg-gray-100 md:p-40 p-20" data-v-c2ab6542><p class="text-18 font-bold" data-v-c2ab6542>MAKE YOUR MEMORIES LAST</p><p class="text-60 font-bold my-20" data-v-c2ab6542>Photo To Art</p><p class="text-22" data-v-c2ab6542>Easily Transform Life&#39;s Real Moments Into A <br data-v-c2ab6542> Masterpiece — Made Just For You.</p></div><script src="/cdn-cgi/scripts/7d0fa10a/cloudflare-static/rocket-loader.min.js" data-cf-settings="186d85ac0b4a505dcf60b85c-|49"></script><img data-nuxt-